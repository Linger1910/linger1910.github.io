---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n';
---

<Layout title="Linger - 折腾者 & 开发者" lang="zh">
  <main>
    <section class="hero">
      <div class="prompt">
        <span class="symbol">$</span>
        <span class="command">whoami</span>
      </div>

      <h1>
        <span class="keyword">{t('hero.greeting', 'zh')}</span>
        <span class="name">Linger</span>
      </h1>

      <p class="tagline">{t('hero.tagline', 'zh')}</p>
    </section>

    <section class="about">
      <div class="prompt">
        <span class="symbol">$</span>
        <span class="command">{t('about.command', 'zh')}</span>
      </div>

      <div class="content">
        <p>{t('about.content', 'zh')}</p>
        <p class="signature">
          <span class="comment">{t('about.signature', 'zh')}</span>
        </p>
      </div>
    </section>

    <section class="interests">
      <div class="prompt">
        <span class="symbol">$</span>
        <span class="command">{t('interests.command', 'zh')}</span>
      </div>

      <ul class="list">
        <li><span class="bullet">→</span> {t('interests.ai', 'zh')}</li>
        <li><span class="bullet">→</span> {t('interests.opensource', 'zh')}</li>
        <li><span class="bullet">→</span> {t('interests.indie', 'zh')}</li>
        <li><span class="bullet">→</span> {t('interests.philosophy', 'zh')}</li>
      </ul>
    </section>

    <section class="links">
      <div class="prompt">
        <span class="symbol">$</span>
        <span class="command">{t('links.command', 'zh')}</span>
      </div>

      <nav class="nav-links">
        <a href="https://github.com/Linger1910" target="_blank" rel="noopener">
          <span class="bracket">[</span>{t('nav.github', 'zh')}<span class="bracket">]</span>
        </a>
        <span class="separator">//</span>
        <a href="/zh/blog">
          <span class="bracket">[</span>{t('nav.blog', 'zh')}<span class="bracket">]</span>
        </a>
        <span class="separator">//</span>
        <a href="/zh/contact">
          <span class="bracket">[</span>{t('nav.contact', 'zh')}<span class="bracket">]</span>
        </a>
      </nav>
    </section>

    <section class="cursor">
      <span class="blink">▌</span>
    </section>
  </main>
</Layout>

<style>
  main {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .prompt {
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }

  .symbol {
    color: var(--accent-green);
    margin-right: 0.5rem;
  }

  .command {
    color: var(--accent-yellow);
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .keyword {
    color: var(--text-secondary);
  }

  .name {
    color: var(--accent-cyan);
  }

  .tagline {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .about .content p {
    margin-bottom: 1rem;
    line-height: 1.8;
  }

  .comment {
    color: var(--text-secondary);
    font-style: italic;
  }

  .signature {
    margin-top: 1.5rem;
  }

  .list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .bullet {
    color: var(--accent-green);
    margin-right: 0.75rem;
  }

  .nav-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .bracket {
    color: var(--text-secondary);
  }

  .separator {
    color: var(--border-color);
    margin: 0 0.5rem;
  }

  .cursor {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--border-color);
  }

  .blink {
    animation: blink 1s infinite;
    color: var(--accent-green);
    font-size: 1.25rem;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  @media (max-width: 600px) {
    .hero h1 {
      font-size: 1.75rem;
    }

    .terminal-body {
      padding: 1.5rem;
    }
  }
</style>
