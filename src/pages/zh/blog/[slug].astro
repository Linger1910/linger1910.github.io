---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { t } from '../../../i18n';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => post.data.lang === 'zh')
    .map((post) => ({
      params: { slug: post.data.slug || post.id.replace(/\.md$/, '') },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date): string {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title={`${post.data.title} - Linger`} lang="zh">
  <main>
    <section class="header">
      <div class="prompt">
        <span class="symbol">$</span>
        <span class="command">cat {post.id}</span>
      </div>
      <a href="/zh/blog" class="back-link">
        <span class="bracket">[</span>{t('blog.backPosts', 'zh')}<span class="bracket">]</span>
      </a>
    </section>

    <article class="post">
      <header class="post-header">
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-meta">
          <time class="date" datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
          {post.data.tags.length > 0 && (
            <div class="tags">
              {post.data.tags.map((tag: string) => (
                <span class="tag">#{tag}</span>
              ))}
            </div>
          )}
        </div>
      </header>

      <div class="post-content">
        <Content />
      </div>
    </article>

    <section class="cursor">
      <span class="blink">▌</span>
    </section>
  </main>
</Layout>

<style>
  main {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .prompt {
    font-size: 0.9rem;
  }

  .symbol {
    color: var(--accent-green);
    margin-right: 0.5rem;
  }

  .command {
    color: var(--accent-yellow);
  }

  .back-link {
    font-size: 0.875rem;
  }

  .bracket {
    color: var(--text-secondary);
  }

  .post {
    border-left: 2px solid var(--border-color);
    padding-left: 1.5rem;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--accent-cyan);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .date {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    color: var(--accent-purple);
    font-size: 0.85rem;
  }

  .post-content {
    line-height: 1.8;
    color: var(--text-primary);
  }

  .post-content :global(h2) {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--accent-green);
    margin: 2rem 0 1rem;
  }

  .post-content :global(h3) {
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--accent-yellow);
    margin: 1.5rem 0 0.75rem;
  }

  .post-content :global(p) {
    margin-bottom: 1rem;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(code) {
    background: var(--code-bg);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .post-content :global(pre) {
    background: var(--code-bg);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1rem 0;
    border: 1px solid var(--border-color);
  }

  .post-content :global(pre code) {
    padding: 0;
    background: none;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--accent-purple);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .post-content :global(a) {
    color: var(--accent-cyan);
  }

  .post-content :global(a:hover) {
    color: var(--accent-green);
  }

  .cursor {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--border-color);
  }

  .blink {
    animation: blink 1s infinite;
    color: var(--accent-green);
    font-size: 1.25rem;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  @media (max-width: 600px) {
    .post-title {
      font-size: 1.4rem;
    }

    .post {
      padding-left: 1rem;
    }

    .post-content :global(pre) {
      padding: 0.75rem;
    }
  }
</style>
