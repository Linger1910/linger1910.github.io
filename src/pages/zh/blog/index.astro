---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n';

const posts = (await getCollection('blog'))
  .filter((post) => post.data.lang === 'zh')
  .sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );

function formatDate(date: Date): string {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}
---

<Layout title="博客 - Linger" lang="zh">
  <main>
    <section class="header">
      <div class="prompt">
        <span class="symbol">$</span>
        <span class="command">ls ./{t('blog.title', 'zh')}</span>
      </div>
      <a href="/zh" class="back-link">
        <span class="bracket">[</span>{t('blog.backHome', 'zh')}<span class="bracket">]</span>
      </a>
    </section>

    <section class="posts">
      {posts.length === 0 ? (
        <p class="empty">{t('blog.noPosts', 'zh')}</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li class="post-item">
              <article>
                <a href={`/zh/blog/${post.id.replace(/\.md$/, '')}/`} class="post-title">
                  <span class="bullet">→</span>
                  {post.data.title}
                </a>
                <div class="post-meta">
                  <span class="date">{formatDate(post.data.pubDate)}</span>
                  {post.data.tags.length > 0 && (
                    <span class="tags">
                      {post.data.tags.map((tag: string) => (
                        <span class="tag">#{tag}</span>
                      ))}
                    </span>
                  )}
                </div>
                <p class="post-desc">{post.data.description}</p>
              </article>
            </li>
          ))}
        </ul>
      )}
    </section>

    <section class="cursor">
      <span class="blink">▌</span>
    </section>
  </main>
</Layout>

<style>
  main {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .prompt {
    font-size: 0.9rem;
  }

  .symbol {
    color: var(--accent-green);
    margin-right: 0.5rem;
  }

  .command {
    color: var(--accent-yellow);
  }

  .back-link {
    font-size: 0.875rem;
  }

  .bracket {
    color: var(--text-secondary);
  }

  .empty {
    color: var(--text-secondary);
    font-style: italic;
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-item {
    border-left: 2px solid var(--border-color);
    padding-left: 1.25rem;
    transition: border-color 0.2s;
  }

  .post-item:hover {
    border-left-color: var(--accent-green);
  }

