---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Linger - Tinkerer & Developer">
  <main>
    <section class="hero">
      <div class="prompt">
        <span class="symbol">$</span>
        <span class="command">whoami</span>
      </div>

      <h1>
        <span class="keyword">Hi, I'm</span>
        <span class="name">Linger</span>
      </h1>

      <p class="tagline">
        Tinkerer. Independent Developer. Building small things, sometimes they work.
      </p>
    </section>

    <section class="about">
      <div class="prompt">
        <span class="symbol">$</span>
        <span class="command">cat about.txt</span>
      </div>

      <div class="content">
        <p>
          Exploring <span class="highlight">AI-native development workflow</span>.
          I build things with the help of AI assistants, learning and creating along the way.
        </p>
        <p class="signature">
          <span class="comment">// Building in public, sharing the journey.</span>
        </p>
      </div>
    </section>

    <section class="interests">
      <div class="prompt">
        <span class="symbol">$</span>
        <span class="command">ls ./interests/</span>
      </div>

      <ul class="list">
        <li><span class="bullet">→</span> AI-Native Development</li>
        <li><span class="bullet">→</span> Open Source Projects</li>
        <li><span class="bullet">→</span> Independent Building</li>
        <li><span class="bullet">→</span> Technology & Philosophy</li>
      </ul>
    </section>

    <section class="links">
      <div class="prompt">
        <span class="symbol">$</span>
        <span class="command">echo $LINKS</span>
      </div>

      <nav class="nav-links">
        <a href="https://github.com/Linger1910" target="_blank" rel="noopener">
          <span class="bracket">[</span>GitHub<span class="bracket">]</span>
        </a>
        <span class="separator">//</span>
        <a href="/blog">
          <span class="bracket">[</span>Blog<span class="bracket">]</span>
        </a>
        <span class="separator">//</span>
        <a href="/contact">
          <span class="bracket">[</span>Contact<span class="bracket">]</span>
        </a>
      </nav>
    </section>

    <section class="cursor">
      <span class="blink">▌</span>
    </section>
  </main>
</Layout>

<style>
  main {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .prompt {
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }

  .symbol {
    color: var(--accent-green);
    margin-right: 0.5rem;
  }

  .command {
    color: var(--accent-yellow);
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .keyword {
    color: var(--text-secondary);
  }

  .name {
    color: var(--accent-cyan);
  }

  .tagline {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .about .content p {
    margin-bottom: 1rem;
    line-height: 1.8;
  }

  .highlight {
    color: var(--accent-purple);
    font-weight: 500;
  }

  .comment {
    color: var(--text-secondary);
    font-style: italic;
  }

  .signature {
    margin-top: 1.5rem;
  }

  .list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .bullet {
    color: var(--accent-green);
    margin-right: 0.75rem;
  }

  .nav-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .bracket {
    color: var(--text-secondary);
  }

  .separator {
    color: var(--border-color);
    margin: 0 0.5rem;
  }

  .cursor {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--border-color);
  }

  .blink {
    animation: blink 1s infinite;
    color: var(--accent-green);
    font-size: 1.25rem;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  @media (max-width: 600px) {
    .hero h1 {
      font-size: 1.75rem;
    }

    .terminal-body {
      padding: 1.5rem;
    }
  }
</style>
